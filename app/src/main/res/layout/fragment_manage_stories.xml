<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F9FA"
    android:padding="16dp">

    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Quản Lý Truyện"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="#333333"
        android:layout_marginBottom="16dp"/>

    <LinearLayout
        android:id="@+id/table_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/tvTitle"
        android:background="#E0E0E0"
        android:padding="8dp"
        android:orientation="horizontal"
        android:weightSum="10">

        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="4" android:text="Tên truyện" android:textStyle="bold" android:textColor="#000"/>
        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="2.5" android:text="Số chương" android:textStyle="bold" android:textColor="#000" android:gravity="center"/>
        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="3.5" android:text="Hành động" android:textStyle="bold" android:textColor="#000" android:gravity="center"/>
    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvAdminStories"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/table_header"
        android:layout_above="@id/btnAddStory"
        android:layout_marginTop="4dp"
        android:layout_marginBottom="16dp"/>

    <Button
        android:id="@+id/btnAddStory"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:text="Đăng truyện mới"
        android:backgroundTint="#E91E63"
        android:textColor="@color/white"
        android:textStyle="bold"
        android:padding="12dp"/>

</RelativeLayout>