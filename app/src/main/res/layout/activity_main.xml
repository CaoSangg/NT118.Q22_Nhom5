<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F9FA">

    <LinearLayout
        android:id="@+id/layout_fixed_top"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:elevation="4dp"
        android:background="@color/white">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="12dp">

            <TextView
                android:id="@+id/tvLogo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="NHÓM 5"
                android:textColor="#E91E63"
                android:fontFamily="sans-serif-black"
                android:textSize="18sp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="38dp"
                android:layout_marginStart="12dp"
                android:layout_marginEnd="8dp"
                android:background="@drawable/search"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="12dp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toEndOf="@id/tvLogo"
                app:layout_constraintEnd_toStartOf="@+id/btnMenuMore">

                <ImageView
                    android:id="@+id/ivSearchIcon"
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@android:drawable/ic_menu_search"
                    app:tint="#999999" />
                <EditText
                    android:id="@+id/etSearchMain"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@android:color/transparent"
                    android:hint="Tìm truyện..."
                    android:textSize="13sp"
                    android:layout_marginStart="8dp"
                    android:inputType="text|textNoSuggestions"
                    android:imeOptions="actionSearch" />
            </LinearLayout>

            <ImageView
                android:id="@+id/btnMenuMore"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:src="@android:drawable/ic_menu_more"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:tint="#333333" />
        </androidx.constraintlayout.widget.ConstraintLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#F39C12"
            android:orientation="horizontal"
            android:padding="12dp"
            android:weightSum="4">

            <TextView
                android:id="@+id/btn_home"
                style="@style/SubMenuStyle"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:gravity="center"
                android:text="Trang chủ" />

            <TextView
                android:id="@+id/btn_the_loai"
                style="@style/SubMenuStyle"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:gravity="center"
                android:text="Thể Loại" />

            <TextView
                android:id="@+id/btn_xep_hang"
                style="@style/SubMenuStyle"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:gravity="center"
                android:text="Xếp Hạng" />

            <TextView
                android:id="@+id/btn_truyen_hot"
                style="@style/SubMenuStyle"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:gravity="center"
                android:text="Truyện Hot" />
        </LinearLayout>

    </LinearLayout>

    <androidx.fragment.app.FragmentContainerView
        android:id="@+id/fragment_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/layout_fixed_top"
        android:layout_alignParentBottom="true" />
</RelativeLayout>