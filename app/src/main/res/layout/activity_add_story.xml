<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Đăng Truyện Mới"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#333333"
            android:layout_marginBottom="16dp"
            android:layout_gravity="center"/>

        <ImageView
            android:id="@+id/imgAddCover"
            android:layout_width="120dp"
            android:layout_height="160dp"
            android:layout_gravity="center"
            android:scaleType="centerCrop"
            android:src="@drawable/ic_launcher_background" />

        <Button
            android:id="@+id/btnPickCover"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="8dp"
            android:text="Chọn ảnh bìa" />

        <EditText
            android:id="@+id/etAddId"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Mã truyện (VD: ST0001)"
            android:layout_marginTop="12dp"
            android:padding="12dp"
            android:background="#FFFFFF"/>

        <EditText
            android:id="@+id/etAddTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Tên truyện"
            android:layout_marginTop="12dp"
            android:padding="12dp"
            android:background="#FFFFFF"/>

        <EditText
            android:id="@+id/etAddAuthor"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Tác giả"
            android:layout_marginTop="12dp"
            android:padding="12dp"
            android:background="#FFFFFF"/>

        <EditText
            android:id="@+id/etAddCategory"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Thể loại (Cách nhau bởi dấu phẩy. VD: Manga, Hài hước)"
            android:layout_marginTop="12dp"
            android:padding="12dp"
            android:background="#FFFFFF"/>

        <EditText
            android:id="@+id/etAddKeywords"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Từ khóa tìm kiếm (VD: doremon, meo may)"
            android:layout_marginTop="12dp"
            android:padding="12dp"
            android:background="#FFFFFF"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Trạng thái truyện:"
            android:layout_marginTop="12dp"/>

        <Spinner
            android:id="@+id/spinnerAddStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:padding="12dp"
            android:background="#FFFFFF"/>

        <EditText
            android:id="@+id/etAddDescription"
            android:layout_width="match_parent"
            android:layout_height="100dp"
            android:gravity="top|start"
            android:hint="Mô tả chi tiết"
            android:inputType="textMultiLine"
            android:layout_marginTop="12dp"
            android:padding="12dp"
            android:background="#FFFFFF"/>

        <Button
            android:id="@+id/btnSubmitStory"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="24dp"
            android:backgroundTint="#E91E63"
            android:text="TẠO TRUYỆN"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:padding="16dp"/>
    </LinearLayout>
</ScrollView>