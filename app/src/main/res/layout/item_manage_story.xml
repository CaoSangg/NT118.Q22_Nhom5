<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:padding="8dp"
    android:background="@color/white"
    android:layout_marginBottom="4dp"
    android:gravity="center_vertical"
    android:weightSum="10">

    <TextView
        android:id="@+id/tvStoryName"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="4"
        android:text="Tên truyện"
        android:textColor="#333333"
        android:textSize="14sp"
        android:maxLines="2"
        android:ellipsize="end"/>

    <TextView
        android:id="@+id/tvChapterCount"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="2.5"
        android:text="Số chương"
        android:textColor="#666666"
        android:textSize="14sp"
        android:gravity="center"/>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="3.5"
        android:orientation="vertical"
        android:gravity="center">

        <TextView
            android:id="@+id/btnAddChapter"
            android:layout_width="80dp"
            android:layout_height="wrap_content"
            android:layout_marginBottom="6dp"
            android:background="#4CAF50"
            android:padding="6dp"
            android:gravity="center"
            android:text="+ Chương"
            android:textColor="@android:color/white"
            android:textSize="11sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/btnEditStory"
            android:layout_width="80dp"
            android:layout_height="wrap_content"
            android:layout_marginBottom="6dp"
            android:background="#2196F3"
            android:padding="6dp"
            android:gravity="center"
            android:text="Sửa truyện"
            android:textColor="@android:color/white"
            android:textSize="11sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/btnDeleteStory"
            android:layout_width="80dp"
            android:layout_height="wrap_content"
            android:background="#F44336"
            android:padding="6dp"
            android:gravity="center"
            android:text="Xóa truyện"
            android:textColor="@android:color/white"
            android:textSize="11sp"
            android:textStyle="bold" />
    </LinearLayout>
</LinearLayout>